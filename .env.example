APP_ENV=development

BASE_URL=http://localhost
BACKEND_ORIGIN=http://api:8000
HTTP_PORT=80

POSTGRES_DB=koubei
POSTGRES_USER=koubei
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://koubei:change-me@postgres:5432/koubei

REDIS_URL=redis://redis:6379/0
ARTIFACT_ROOT=/srv/koubei/jobs
JOB_ARTIFACTS_HOST_PATH=./storage/jobs
WORKSPACE_ROOT=/workspace
WORKER_QUEUE_NAME=vehicle-koubei
WORKER_JOB_TIMEOUT_SECONDS=3600
VEHICLE_RESOLVE_CACHE_TTL_SECONDS=604800
VEHICLE_RESOLVE_PLATFORM_TIMEOUT_SECONDS=60

PASS_PHRASE_HASH=sha256:f9aa03cd196b5d4d6797a9e792b3f99b871fb535106c41cd566efeec0d722ea8
PASS_PHRASE_VERSION=2026-W17
SESSION_SECRET=change-me

TAVILY_API_KEY=

LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_REPORT=
LLM_MODEL_QA=

# OpenClaw is a per-stage execution adapter, not a replacement for the worker pipeline.
# Collection stages listed in OPENCLAW_ADAPTER_STAGES run through OpenClaw; all other stages stay on the local worker runner.
OPENCLAW_ADAPTER_ENABLED=false
OPENCLAW_ADAPTER_STAGES=collecting_autohome,collecting_dcd
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18790
OPENCLAW_GATEWAY_TOKEN_FILE_HOST=./ops/secrets/openclaw_gateway_token.placeholder
OPENCLAW_GATEWAY_TOKEN_FILE=/run/secrets/openclaw_gateway_token
OPENCLAW_AGENT_ID=main
OPENCLAW_AUTOHOME_AGENT_ID=autohome
OPENCLAW_DCD_AGENT_ID=dongchedi
OPENCLAW_TIMEOUT_SECONDS=1800
OPENCLAW_ARTIFACT_POLL_INTERVAL_SECONDS=5
OPENCLAW_COLLECTOR_SKILL=sh3rlockC/auto-koubei-collector
OPENCLAW_AUTOHOME_COLLECTOR_SKILL=sh3rlockC/auto-koubei-collector
OPENCLAW_DCD_COLLECTOR_SKILL=sh3rlockC/dcd-koubei-collector
OPENCLAW_ARTIFACT_ROOT_HOST=
OPENCLAW_STATE_HOST_PATH=
OPENCLAW_TASK_DB_PATH=/openclaw-state/tasks/runs.sqlite

WORDCLOUD_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
