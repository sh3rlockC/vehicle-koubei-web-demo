COMPOSE_PROJECT_NAME=vehicle-koubei-sandbox
APP_ENV=sandbox
HTTP_PORT=18080
BASE_URL=http://localhost:18080
POSTGRES_DB=koubei
POSTGRES_USER=koubei
POSTGRES_PASSWORD=koubei
DATABASE_URL=postgresql+psycopg://koubei:koubei@postgres:5432/koubei
REDIS_URL=redis://redis:6379/1
WORKER_QUEUE_NAME=vehicle-koubei-sandbox
ARTIFACT_ROOT=/srv/koubei/jobs
JOB_ARTIFACTS_HOST_PATH=.sandbox/vehicle-koubei/storage/jobs
OPENCLAW_STATE_HOST_PATH=.sandbox/vehicle-koubei/openclaw-state
OPENCLAW_GATEWAY_TOKEN_FILE_HOST=.sandbox/vehicle-koubei/secrets/openclaw_gateway_token
JOB_ARTIFACT_RETENTION_DAYS=3
COMPARISON_MODEL_CONCURRENCY=1
TAVILY_API_KEY=
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_BATCH=
LLM_MODEL_REPORT=
LLM_MODEL_QA=
